# ============================================================
# Payload CMS Configuration — wib-payload
# Copy this file to .env and fill in your values
# ============================================================

# --- Payload Core ---
PAYLOAD_SECRET=generate-with-openssl-rand-base64-48
NEXT_PUBLIC_SERVER_URL=https://your-app.onrender.com
PAYLOAD_PORT=3000

# --- Admin user ---
ADMIN_EMAIL=admin@asigurari.ro
ADMIN_PASSWORD=

# --- MongoDB (direct — shared with Symfony) ---
MONGODB_URI=mongodb://192.168.0.31:27017/wib_test
# Production: MONGODB_URI=mongodb://192.168.0.203:27017/wib_test

# --- AI Features ---
OPENAI_API_KEY=sk-...

# --- CORS ---
CORS_ORIGIN=https://www.asigurari.ro

# --- Email (SMTP) ---
EMAIL_FROM=noreply@asigurari.ro
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_SECURE=false

# --- n8n ---
N8N_PORT=5678
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_WEBHOOK_URL=http://n8n:5678
N8N_USER=admin
N8N_PASSWORD=

# --- Preview ---
PREVIEW_SECRET=ee4016c8434b8bfac95a92cb7cc44bb9
SITE_URL=https://www.asigurari.ro
