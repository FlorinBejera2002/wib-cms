# ============================================================
# WIB CMS Configuration
# Copy this file to .env and fill in your values
# ============================================================

# --- NextAuth v5 ---
AUTH_SECRET=generate-with-openssl-rand-hex-32
AUTH_URL=http://localhost:3000

# --- MongoDB (shared with Symfony) ---
MONGODB_URI=mongodb://192.168.0.31:27017/wib_test
# Production: MONGODB_URI=mongodb://192.168.0.203:27017/wib_test

# --- Admin seed user ---
ADMIN_EMAIL=admin@asigurari.ro
ADMIN_PASSWORD=

# --- CORS ---
CORS_ORIGIN=https://www.asigurari.ro

# --- n8n Webhooks ---
N8N_WEBHOOK_URL=http://n8n:5678
WEBHOOK_SECRET=generate-a-secret

# --- Preview ---
PREVIEW_SECRET=ee4016c8434b8bfac95a92cb7cc44bb9
SITE_URL=https://www.asigurari.ro

# --- SEO Article Generator ---
SEO_TOOL_API_URL=https://www.asigurari.ro/ai-assistant/chat-api/v1/tools/seo/article
SEO_TOOL_STATIC_KEY=your-seo-tool-key-here
